#!/usr/bin/env bash
# upstack-config — read/write ~/.upstack/config.yaml
#
# Usage:
#   upstack-config get <key>          — read a config value
#   upstack-config set <key> <value>  — write a config value
#   upstack-config list               — show all config
#
# Env overrides (for testing):
#   UPSTACK_STATE_DIR  — override ~/.upstack state directory
set -euo pipefail

STATE_DIR="${UPSTACK_STATE_DIR:-$HOME/.upstack}"
CONFIG_FILE="$STATE_DIR/config.yaml"

case "${1:-}" in
  get)
    KEY="${2:?Usage: upstack-config get <key>}"
    grep -E "^${KEY}:" "$CONFIG_FILE" 2>/dev/null | tail -1 | awk '{print $2}' | tr -d '[:space:]' || true
    ;;
  set)
    KEY="${2:?Usage: upstack-config set <key> <value>}"
    VALUE="${3:?Usage: upstack-config set <key> <value>}"
    mkdir -p "$STATE_DIR"
    if grep -qE "^${KEY}:" "$CONFIG_FILE" 2>/dev/null; then
      sed -i '' "s/^${KEY}:.*/${KEY}: ${VALUE}/" "$CONFIG_FILE"
    else
      echo "${KEY}: ${VALUE}" >> "$CONFIG_FILE"
    fi
    ;;
  list)
    cat "$CONFIG_FILE" 2>/dev/null || true
    ;;
  *)
    echo "Usage: upstack-config {get|set|list} [key] [value]"
    exit 1
    ;;
esac
